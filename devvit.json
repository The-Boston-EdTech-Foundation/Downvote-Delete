{
  "$schema": "https://developers.reddit.com/schema/config-file.v1.json",
  "name": "downvote-delete",
  "server": {
    "dir": "dist/server",
    "entry": "index.cjs"
  },
  "triggers": {
    "onPostSubmit": "/internal/triggers/on-post-submit",
    "onPostUpdate": "/internal/triggers/on-post-update"
  },
  "scheduler": {
    "tasks": {
      "checkWatchedPost": {
        "endpoint": "/internal/scheduler/check-watched-post"
      }
    }
  },
  "settings": {
    "subreddit": {
      "isActive": {
        "type": "boolean",
        "label": "Downvote Delete is active",
        "helpText": "Disable this to temporarily pause downvote delete from actioning content.",
        "defaultValue": true
      },
      "trackingDurationHours": {
        "type": "select",
        "label": "Track posts for",
        "options": [
          { "label": "1 hour", "value": "1" },
          { "label": "2 hours", "value": "2" },
          { "label": "3 hours", "value": "3" }
        ],
        "defaultValue": "2"
      },
      "negativeScoreThreshold": {
        "type": "select",
        "label": "Action post at score",
        "options": [
          { "label": "-3", "value": "-3" },
          { "label": "-5", "value": "-5" },
          { "label": "-10", "value": "-10" }
        ],
        "defaultValue": "-3"
      },
      "positiveScoreStopThreshold": {
        "type": "select",
        "label": "Stop watching at positive score",
        "options": [
          { "label": "3", "value": "3" },
          { "label": "5", "value": "5" },
          { "label": "10", "value": "10" }
        ],
        "defaultValue": "5"
      },
      "actionToTake": {
        "type": "select",
        "label": "Action to take",
        "options": [
          { "label": "Report to Mod Queue", "value": "report" },
          { "label": "Filter", "value": "filter" },
          { "label": "Remove", "value": "remove" }
        ],
        "defaultValue": "remove"
      },
      "moderatorPostHandling": {
        "type": "select",
        "label": "Moderator post handling",
        "options": [
          { "label": "Ignore downvoted moderator posts", "value": "ignore" },
          {
            "label": "Action all downvoted posts including moderators",
            "value": "action_all"
          }
        ],
        "defaultValue": "ignore"
      }
    }
  },
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch"
  },
  "marketingAssets": {
    "icon": "assets/icon.jpg"
  },
  "permissions": {
    "reddit": {
      "enable": true,
      "scope": "moderator"
    },
    "redis": true
  },
  "dev": {
    "subreddit": "downvote_delete_dev"
  }
}
