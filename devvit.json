{
  "$schema": "https://developers.reddit.com/schema/config-file.v1.json",
  "name": "downvote-delete",
  "server": {
    "dir": "dist/server",
    "entry": "index.cjs"
  },
  "triggers": {
    "onPostSubmit": "/internal/triggers/on-post-submit"
  },
  "scheduler": {
    "tasks": {
      "checkWatchedPost": {
        "endpoint": "/internal/scheduler/check-watched-post"
      }
    }
  },
  "settings": {
    "global": {
      "REDDIT_CLIENT_ID": {
        "type": "string",
        "label": "Reddit OAuth client ID",
        "isSecret": true
      },
      "REDDIT_CLIENT_SECRET": {
        "type": "string",
        "label": "Reddit OAuth client secret",
        "isSecret": true
      },
      "REDDIT_REFRESH_TOKEN": {
        "type": "string",
        "label": "Reddit OAuth refresh token",
        "isSecret": true
      },
      "REDDIT_USER_AGENT": {
        "type": "string",
        "label": "Reddit API user agent",
        "defaultValue": "Downvote-Delete/1.4.1 by Alan-Foster"
      }
    },
    "subreddit": {
      "isActive": {
        "type": "boolean",
        "label": "Downvote Delete is active",
        "helpText": "Disable this to temporarily pause downvote delete from actioning content.",
        "defaultValue": true
      },
      "trackingDurationHours": {
        "type": "select",
        "label": "Track posts for",
        "options": [
          { "label": "2 hours", "value": "2" },
          { "label": "4 hours", "value": "4" },
          { "label": "6 hours", "value": "6" }
        ],
        "defaultValue": "4"
      },
      "negativeScoreThreshold": {
        "type": "select",
        "label": "Action post at score",
        "options": [
          { "label": "-1", "value": "-1" },
          { "label": "-2", "value": "-2" },
          { "label": "-3", "value": "-3" },
          { "label": "-4", "value": "-4" },
          { "label": "-5", "value": "-5" }
        ],
        "defaultValue": "-3"
      },
      "positiveScoreStopThreshold": {
        "type": "select",
        "label": "Stop watching at positive score",
        "options": [
          { "label": "3", "value": "3" },
          { "label": "5", "value": "5" },
          { "label": "10", "value": "10" }
        ],
        "defaultValue": "5"
      },
      "actionToTake": {
        "type": "select",
        "label": "Action to take",
        "options": [
          { "label": "Report to Mod Queue", "value": "report" },
          { "label": "Filter", "value": "filter" },
          { "label": "Remove", "value": "remove" }
        ],
        "defaultValue": "remove"
      },
      "moderatorPostHandling": {
        "type": "select",
        "label": "Moderator post handling",
        "options": [
          { "label": "Ignore downvoted moderator posts", "value": "ignore" },
          {
            "label": "Action all downvoted posts including moderators",
            "value": "action_all"
          }
        ],
        "defaultValue": "ignore"
      }
    }
  },
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch"
  },
  "marketingAssets": {
    "icon": "assets/icon.png"
  },
  "permissions": {
    "reddit": {
      "enable": true,
      "scope": "moderator"
    },
    "redis": true,
    "http": {
      "enable": true,
      "domains": ["oauth.reddit.com"]
    }
  },
  "dev": {
    "subreddit": "downvote_delete_dev"
  }
}
